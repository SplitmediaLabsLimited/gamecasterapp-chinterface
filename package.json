{
  "name": "chinterface",
  "version": "3.0.9",
  "description": "Universal Chat interface library for popular stream services",
  "main": "dist/chinterface.js",
  "unpkg": "dist/chinterface.umd.js",
  "module": "dist/chinterface.modern.js",
  "source": "src/chat.js",
  "scripts": {
    "build": "microbundle --globals tmi.js=tmi --external tmi.js -f modern,cjs,umd",
    "format": "prettier --single-quote --tab-width 2 --write 'src/**/*.js'",
    "prepare": "yarn run build"
  },
  "devDependencies": {
    "html-entities": "^1.3.1",
    "microbundle": "0.12.4",
    "prettier": "^2.1.2",
    "protobufjs-cli": "^2.5.6",
    "tmi.js": "1.7.2"
  },
  "peerDependencies": {
    "tmi.js": ">= 1.5.0"
  },
  "files": [
    "dist/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gamecasterapp/chinterface.git"
  },
  "keywords": [
    "Chat",
    "Twitch",
    "Youtube"
  ],
  "author": "Gamecaster",
  "license": "MIT",
  "homepage": "",
  "dependencies": {
    "redaxios": "^0.3.0"
  },
  "volta": {
    "node": "14.20.0",
    "yarn": "1.22.22"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
